# Challenge No.15 : Perfect Number 
# Ask the uset to enter a positive interger

num = int(input("Enter a positive integer : "))
# Initialize the variable with 0 to hold the sum
div = 0

# Check if the entered integer is greater than 0 or not
if num > 0:
    # Use loop to find proper divisors of the integer
    for i in range(1,num):
        # Use conditional statement to check whether the number is perfectly divisble by i
        if num % i == 0:
            # Increment the variable
            div +=i

    # Use conditional statement to check the sum of all div == num
    if div == num:
        print(f"{num} is a perfect number")
    else:
        print(f"{num} is not a perfect number")

# If the entered number is not positive display the following statement
else :
    print("The entered integer is invalid. Enter a positive integer")
    
        
        
