# Challenge No.22 : Number Pyramid 
# Ask the user to enter the nummber of rows
rows = int(input("Enter the number of rows: "))

for i in range(1, rows + 1):
    # Print leading spaces for alignment
    print(" " * (rows - i), end="")

    # Increasing sequence
    for j in range(i, 2 * i):
        print(j, end="")

    # Decreasing sequence
    for j in range(2 * i - 2, i - 1, -1):
        print(j, end="")
  
    # move to next line
    print()
